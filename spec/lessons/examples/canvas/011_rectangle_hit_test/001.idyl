use colors;
use drawable;
use gui;

drawable.Rectangle rect;

bool function point_inside_rect(int x, int y) {
    return (x >= rect.x) and
           (x <= rect.x + rect.width) and
           (y >= rect.y) and
           (y <= rect.y + rect.height);
}

void function redraw(gui.Canvas canvas) {
    canvas.fill(colors.RGB(20, 24, 32));
    canvas.draw(rect);
}

void function init(gui.Canvas canvas) {
    rect.x = 100;
    rect.y = 150;
    rect.width = 60;
    rect.height = 40;
    rect.fill_color = colors.RGB(34, 145, 188);
    redraw(canvas);
}

void function on_mouse_move(gui.Canvas canvas, gui.MouseEvent e) {
    if (point_inside_rect(e.x, e.y)) {
        rect.fill_color = colors.RGB(255, 210, 80);
    } else {
        rect.fill_color = colors.RGB(34, 145, 188);
    }

    redraw(canvas);
}

main() {
    gui.Window win;
    win.width = 360;
    win.height = 280;
    win.title = "Точка в прямоугольнике";

    gui.Canvas canvas;
    canvas.x = 20;
    canvas.y = 20;
    canvas.width = 300;
    canvas.height = 210;
    canvas.on_init = init;
    canvas.on_mouse_move = on_mouse_move;

    win.add_child(canvas);
    win.show();
}
