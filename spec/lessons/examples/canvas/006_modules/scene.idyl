use colors;
use drawable;
use gui;

drawable.Circle ball;

void function redraw(gui.Canvas canvas) {
    canvas.fill(colors.RGB(20, 24, 32));
    canvas.draw(ball);
}

void function init(gui.Canvas canvas) {
    ball.x = 190;
    ball.y = 115;
    ball.radius = 25;
    ball.fill_color = colors.RGB(255, 210, 80);
    redraw(canvas);
}

void function on_mouse_move(gui.Canvas canvas, gui.MouseEvent e) {
    ball.x = e.x;
    ball.y = e.y;
    redraw(canvas);
}
