use console;

main() {
    console.write("Введите число: ");
    int N = console.get_int();

    if (N > 0) {
        console.writeln("Ваше число положительное!");
    }
    if (N < 0) {
        console.writeln("Ваше число отрицательное!");
    }
    if (N == 0) {
        console.writeln("Ваше число равно нулю!");
    }
}