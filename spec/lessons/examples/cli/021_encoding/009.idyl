use console;
use encoding;

main() {
    string original = "Привет";
    dyn_array<int> encoded = encoding.encode(original, "windows-1251");
    string decoded = encoding.decode(encoded, "windows-1251");
    console.writeln("Исходник: ", original);
    console.writeln("Коды: ", encoded);
    console.writeln("Обратно: ", decoded);
}