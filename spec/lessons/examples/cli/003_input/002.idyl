use console;

main() {
    console.write("Сейчас посчитаем периметр треугольника", '\n');

    console.write("Введите первую сторону: ");
    int A = console.get_int();

    console.write("Введите вторую сторону: ");
    int B = console.get_int();

    console.write("Введите третью сторону: ");
    int C = console.get_int();

    int P = A + B + C;
    console.write("Периметр равен: ", P, '\n');
}