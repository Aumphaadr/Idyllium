// main.idyl
use console;

main() {
    // тип 'int': только для целых чисел
    int A = 2; // можно
    int B = 1.7; // нельзя — ошибка!

    // тип 'float': только для дробных чисел
    float C = 4.62; // можно
    float D = 5; // можно — станет 5.0
    float E = "текст"; // нельзя — ошибка!

    // тип 'string': только для текста в кавычках
    string F = "ЪЕЪ или ЪУЪ?"; // можно
    string G = "дайте 64 алмаза"; // можно
    string H = 56692; // нельзя — ошибка!
}