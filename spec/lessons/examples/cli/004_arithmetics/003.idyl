use console;

main() {
    int A = 10;
    float B = 2.5;

    float C = A + B; // 'int' + 'float' → 'float'
    console.write(C, '\n');

    float D = A - B; // 'int' - 'float' → 'float'
    console.write(D, '\n');

    float E = A * B; // 'int' * 'float' → 'float'
    console.write(E, '\n');

    float F = A / B; // 'int' / 'float' → 'float'
    console.write(F, '\n');
}