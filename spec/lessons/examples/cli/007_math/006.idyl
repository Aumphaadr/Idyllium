use console;
use math;

main() {
    console.writeln(math.clamp(0, 5, 10));      // 5
    console.writeln(math.clamp(0, -3, 10));     // 0
    console.writeln(math.clamp(0, 15, 10));     // 10

    // Пример: ограничить уровень громкости от 0 до 100
    int volume = 115;
    volume = math.clamp(0, volume, 100);
    console.writeln("Громкость: ", volume); // 100
}