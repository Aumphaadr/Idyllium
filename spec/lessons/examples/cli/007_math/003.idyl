use console;
use math;

main() {
    float x = 3.6789;

    console.writeln("Исходное число: ", x);

    console.writeln("round(x): ", math.round(x));       // 4
    console.writeln("floor(x): ", math.floor(x));       // 3
    console.writeln("ceil(x): ", math.ceil(x));         // 4

    console.writeln("round(x, 2): ", math.round(x, 2)); // 3.68
    console.writeln("floor(x, 2): ", math.floor(x, 2)); // 3.67
    console.writeln("ceil(x, 2): ", math.ceil(x, 2));   // 3.68
}