use console;
use time;

main() {
    time.stamp t = time.now();
    console.writeln("Год: ", t.year());
    console.writeln("Месяц: ", t.month());
    console.writeln("День: ", t.day());
    console.writeln("Час: ", t.hour());
    console.writeln("Минута: ", t.minute());
    console.writeln("Секунда: ", t.second());
    console.writeln("День недели: ", t.week_day());
}