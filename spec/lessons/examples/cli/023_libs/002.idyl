// main.idyl — главный файл проекта
use console;
use time;
use draw; // подключаем нашу библиотеку (без .idyl)

main() {
    // Вызываем функцию из системной библиотеки 'time'
    time.sleep(1);

    // Вызываем функцию из нашей собственной библиотеки 'draw'
    draw.line(10); // выведет "----------"
}