use console;

main() {
    console.writeln("\e[31m", "Красный текст");
    console.writeln("\e[32m", "Зелёный текст");
    console.writeln("\e[33m", "Жёлтый текст");
    console.writeln("\e[34m", "Синий текст");
    console.writeln("\e[35m", "Малиновый текст");
    
    console.writeln("\e[0m", "Стандартный текст");
}