use console;

main() {
    console.writeln("\e[32m", "Текст стал зелёным");
    console.writeln("Текст всё ещё зелёный");
    console.writeln("Пока цвет не поменять, он будет зелёным");

    console.writeln("\e[31m", "А теперь текст стал красным");
    console.writeln("И он останется красным");
    console.writeln("Пока не поменять на другой");
}