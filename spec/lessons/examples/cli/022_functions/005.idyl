use console;

// описание void-функции
void function draw_line(int L) {
    string res = "";
    for (int i = 0; i < L; i = i + 1) {
        res = res + '-';
    }
    console.writeln(res);
}

main() {
    // вызовы void-функции
    draw_line(5);  // приняла 5, вывела "-----", ничего не породила
    draw_line(12); // приняла 12, вывела "------------", ничего не породила
}