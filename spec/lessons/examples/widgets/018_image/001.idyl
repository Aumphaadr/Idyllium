use gui;

main() {
    gui.Window win;
    win.width = 420;
    win.height = 300;
    win.title = "Картинка";

    gui.Image picture;
    picture.x = 40;
    picture.y = 30;
    picture.width = 320;
    picture.height = 220;
    picture.load_from_file("cat.png");

    win.add_child(picture);
    win.show();
}
