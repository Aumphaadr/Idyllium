use gui;

main() {
    gui.Window win;
    win.width = 300;
    win.height = 150;
    win.title = "Alert";

    gui.Button btn;
    btn.text = "Показать уведомление";
    btn.x = 30;
    btn.y = 50;
    btn.width = 240;

    btn.on_click = void function(gui.Button sender) {
        gui.Modal m;
        m.title = "Уведомление";
        m.message = "Это простое информационное сообщение.";
        m.confirm_text = "Понятно";
        m.show_alert();
    };

    win.add_child(btn);
    win.show();
}