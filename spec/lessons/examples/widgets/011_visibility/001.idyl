use gui;

main() {
    gui.Window win;
    win.width = 350;
    win.height = 180;
    win.title = "Видимость прогрессбаров";

    gui.ProgressBar pb1;
    pb1.x = 20;
    pb1.y = 30;
    pb1.width = 310;
    pb1.value = 75;

    gui.ProgressBar pb2;
    pb2.x = 20;
    pb2.y = 80;
    pb2.width = 310;
    pb2.value = 30;
    pb2.visible = false;  // скрыт

    win.add_child(pb1);
    win.add_child(pb2);
    win.show();
}