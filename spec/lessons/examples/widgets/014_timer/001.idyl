use gui;
use random;

main() {
    gui.Window win;
    win.width = 300;
    win.height = 150;
    win.title = "Случайные числа";

    gui.Label label;
    label.x = 50;
    label.y = 50;
    label.font_size = 24;
    label.text = "0";

    gui.Timer timer;
    timer.interval = 1000;  // 1 секунда

    timer.on_tick = void function() {
        int r = random.create_int(1, 100);
        label.text = to_string(r);
    };

    timer.start();

    win.add_child(label);
    win.show();
}