use gui;

main() {
    gui.Window win;
    win.width = 300;
    win.height = 150;
    win.title = "FloatSpinBox";

    gui.FloatSpinBox spin;
    spin.x = 20;
    spin.y = 20;
    spin.width = 140;
    spin.value = 0.5;
    spin.min = 0.0;
    spin.max = 1.0;
    spin.step = 0.1;

    win.add_child(spin);
    win.show();
}