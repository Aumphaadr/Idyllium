use gui;

main() {
    gui.Window win;
    win.width = 250;
    win.height = 150;
    win.title = "RadioButton";

    gui.RadioButton rb1;
    rb1.x = 20;
    rb1.y = 20;
    rb1.text = "Вариант 1";

    gui.RadioButton rb2;
    rb2.x = 20;
    rb2.y = 50;
    rb2.text = "Вариант 2";

    gui.RadioButton rb3;
    rb3.x = 20;
    rb3.y = 80;
    rb3.text = "Вариант 3";

    win.add_child(rb1);
    win.add_child(rb2);
    win.add_child(rb3);
    win.show();
}