use gui;

main() {
    gui.Window win;
    win.width = 350;
    win.height = 150;
    win.title = "Настройки LineEdit";

    gui.LineEdit input;
    input.x = 20;
    input.y = 20;
    input.width = 310;
    input.font_size = 16;
    input.placeholder = "Введите текст здесь...";

    win.add_child(input);
    win.show();
}