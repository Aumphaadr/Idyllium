use gui;

main() {
    gui.Window win;
    win.width = 400;
    win.height = 200;

    gui.Label label;
    label.x = 20;
    label.y = 20;
    label.text = "Широкая электрификация южных губерний";

    gui.Button btn;
    btn.x = 50;
    btn.y = 20;
    btn.text = "Нажми меня";

    win.add_child(label);
    win.add_child(btn);
    win.show();
}