use gui;

main() {
    gui.Window win;
    win.width = 300;
    win.height = 150;

    gui.Label label;
    label.text = "Длинный текст длинный текст длинный текст";
    label.x = 20;
    label.y = 20;

    gui.Button btn;
    btn.x = 30;
    btn.y = 20;
    btn.text = "Кнопка";

    win.add_child(label);  // label будет снизу
    win.add_child(btn);    // btn — сверху (перекрывает label)

    win.show();
}