use gui;

main() {
    gui.Window win;
    gui.Label label;
    label.text = "Жду...";
    
    gui.Timer timer;
    timer.interval = 1000;
    timer.on_tick = void function() {
        label.text = "Прошла секунда";
    };
    // timer.start(); ← забыли!
    
    win.add_child(label);
    win.show();
}