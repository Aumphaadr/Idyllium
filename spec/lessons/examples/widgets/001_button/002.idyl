use gui;

main() {
    gui.Window win;
    win.width = 300;
    win.height = 200;
    win.title = "Рабочая кнопка";

    gui.Button btn;
    btn.text = "Нажми меня";
    btn.x = 50;
    btn.y = 50;

    // Присваиваем функцию-обработчик
    btn.on_click = void function() {
        btn.text = "Кнопка нажата!";
    };

    win.add_child(btn);
    win.show();
}