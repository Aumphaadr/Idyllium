use console;

class Cat {
    string name;

    constructor Cat(string ex_name) {
        this.name = ex_name;
    }

    string function to_string() {
        return "Cat(" + this.name + ")";
    }
}

main() {
    Cat cat1("Барсик");
    Cat cat2("Мурка");

    console.writeln(cat1);
    console.writeln(cat2);
}