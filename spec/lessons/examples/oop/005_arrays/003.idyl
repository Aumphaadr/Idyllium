class Dog {
    string name;
    int age;

    void function bark() {
        console.writeln(this.name, " гавкнул!");
    }
}

main() {
    array<Dog, 3> dogs;

    dogs[0].name = "Шарик";
    dogs[1].name = "Бобик";
    dogs[2].name = "Рекс";

    dogs[0].age = 3;
    dogs[1].age = 5;
    dogs[2].age = 2;
}