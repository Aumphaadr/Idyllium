use console;
use rect;   // подключаем rect.idyl

main() {
    rect.Rect r1;           // создаём прямоугольник
    r1.width = 20;          // задаём ширину
    r1.height = 30;         // задаём высоту

    console.writeln("Площадь равна: ", r1.getArea());

    r1.scaleX(1.3);         // масштабируем по оси X в 1.3 раза
    console.writeln("После масштабирования: ", r1.getArea());
}