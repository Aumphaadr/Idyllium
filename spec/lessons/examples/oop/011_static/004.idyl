use console;

class MathUtils {
    static int function square(int x) {
        return x * x;
    }

    static int function cube(int x) {
        return x * x * x;
    }

    static bool function is_even(int x) {
        return mod(x, 2) == 0;
    }
}

main() {
    int a = 5;
    console.writeln("Квадрат ", a, ": ", MathUtils.square(a));
    console.writeln("Куб ", a, ": ", MathUtils.cube(a));
    console.writeln(a, " чётное? ", MathUtils.is_even(a));
}