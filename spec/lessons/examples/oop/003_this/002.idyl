use console;

class Cat {
    string name;

    void function meow() {
        console.writeln(this.name, " мяукнул!");
    }
}

main() {
    Cat cat1;
    cat1.name = "Барсик";

    Cat cat2;
    cat2.name = "Мурзик";

    cat1.meow();  // в этот момент this указывает на cat1
    cat2.meow();  // в этот момент this указывает на cat2
}