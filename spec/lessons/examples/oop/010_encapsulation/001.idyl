use console;

class Hero {
    string name;
    int hp;
}

main() {
    Hero hero1;
    hero1.name = "Воин";
    hero1.hp = 40;

    console.writeln(hero1.name, ": ", hero1.hp);

    // Где-то в коде кто-то решил подлечиться
    hero1.hp = hero1.hp + 75;  // 40 + 75 = 115

    console.writeln(hero1.name, ": ", hero1.hp);
}