class Rectangle {
    float width;
    float height;
    int colorR;
    int colorG;
    int colorB;
}

class Circle {
    float radius;
    int colorR;
    int colorG;
    int colorB;
}

main() {
    Rectangle rect;
    rect.width = 10;
    rect.height = 20;
    rect.colorR = 255;
    rect.colorG = 0;
    rect.colorB = 0;

    Circle circ;
    circ.radius = 5;
    circ.colorR = 0;
    circ.colorG = 255;
    circ.colorB = 0;
}