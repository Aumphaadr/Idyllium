{
  "$schema": "vscode://schemas/color-theme",
  "name": "Idyllium Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#120a1d",
    "editor.foreground": "#f0ecf8",
    "editorLineNumber.foreground": "#777088",
    "editorLineNumber.activeForeground": "#d0d6e6",
    "editorCursor.foreground": "#ffffff",
    "editor.selectionBackground": "#6aa4ff45",
    "editor.inactiveSelectionBackground": "#6aa4ff24",
    "editor.lineHighlightBackground": "#ffffff07",
    "editor.lineHighlightBorder": "#00000000",
    "editorBracketHighlight.foreground1": "#d0d6e6",
    "editorBracketHighlight.foreground2": "#d0d6e6",
    "editorBracketHighlight.foreground3": "#d0d6e6",
    "editorBracketHighlight.foreground4": "#d0d6e6",
    "editorBracketHighlight.foreground5": "#d0d6e6",
    "editorBracketHighlight.foreground6": "#d0d6e6",
    "editorBracketMatch.background": "#21182c",
    "editorBracketMatch.border": "#6aa4ff66",
    "editorIndentGuide.background1": "#2a2038",
    "editorIndentGuide.activeBackground1": "#4a405c"
  },
  "semanticTokenColors": {
    "namespace": "#8bdfff",
    "class": "#59d4b8",
    "function": "#e4d87e",
    "method": "#e4d87e",
    "property": "#8bdfff",
    "variable": "#f0ecf8",
    "parameter": "#8bdfff",
    "variable.readonly": "#8bdfff"
  },
  "tokenColors": [
    {
      "scope": [
        "keyword.control.idyllium",
        "keyword.declaration.idyllium",
        "keyword.declaration.import.idyllium",
        "keyword.declaration.class.idyllium",
        "keyword.declaration.extends.idyllium",
        "keyword.operator.logical.idyllium",
        "constant.language.boolean.idyllium"
      ],
      "settings": { "foreground": "#b892ff" }
    },
    {
      "scope": [
        "storage.type.primitive.idyllium",
        "storage.type.numeric.idyllium"
      ],
      "settings": { "foreground": "#63b3ff" }
    },
    {
      "scope": [
        "entity.name.type.class.idyllium",
        "entity.other.inherited-class.idyllium"
      ],
      "settings": { "foreground": "#59d4b8" }
    },
    {
      "scope": [
        "entity.name.function.idyllium",
        "entity.name.function.main.idyllium",
        "entity.name.function.member.idyllium",
        "support.function.builtin.idyllium"
      ],
      "settings": { "foreground": "#e4d87e" }
    },
    {
      "scope": [
        "entity.name.namespace.idyllium",
        "variable.language.this.idyllium",
        "variable.language.parent.idyllium",
        "variable.other.member.idyllium",
        "constant.other.color.idyllium"
      ],
      "settings": { "foreground": "#8bdfff" }
    },
    {
      "scope": [
        "string.quoted.double.idyllium",
        "string.quoted.single.idyllium"
      ],
      "settings": { "foreground": "#d99a6c" }
    },
    {
      "scope": [
        "constant.numeric.float.idyllium",
        "constant.numeric.integer.idyllium"
      ],
      "settings": { "foreground": "#c5d979" }
    },
    {
      "scope": [
        "comment.block.idyllium",
        "comment.line.double-slash.idyllium"
      ],
      "settings": {
        "foreground": "#6ba36f",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.operator.idyllium",
        "punctuation.idyllium"
      ],
      "settings": { "foreground": "#d0d6e6" }
    }
  ]
}
