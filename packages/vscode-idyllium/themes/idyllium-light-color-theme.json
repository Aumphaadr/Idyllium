{
  "$schema": "vscode://schemas/color-theme",
  "name": "Idyllium Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#d9d6df",
    "editor.foreground": "#252730",
    "editorLineNumber.foreground": "#77717f",
    "editorLineNumber.activeForeground": "#47424f",
    "editorCursor.foreground": "#23252c",
    "editor.selectionBackground": "#315f8c38",
    "editor.inactiveSelectionBackground": "#315f8c1c",
    "editor.lineHighlightBackground": "#275f9e0b",
    "editor.lineHighlightBorder": "#00000000",
    "editorBracketHighlight.foreground1": "#445253",
    "editorBracketHighlight.foreground2": "#445253",
    "editorBracketHighlight.foreground3": "#445253",
    "editorBracketHighlight.foreground4": "#445253",
    "editorBracketHighlight.foreground5": "#445253",
    "editorBracketHighlight.foreground6": "#445253",
    "editorBracketMatch.background": "#c6c2cd",
    "editorBracketMatch.border": "#827a8d",
    "editorIndentGuide.background1": "#c4c0ca",
    "editorIndentGuide.activeBackground1": "#9c95a4"
  },
  "semanticTokenColors": {
    "namespace": "#0d667f",
    "class": "#1b745c",
    "function": "#76620f",
    "method": "#76620f",
    "property": "#0d667f",
    "variable": "#252730",
    "parameter": "#0d667f",
    "variable.readonly": "#0d667f"
  },
  "tokenColors": [
    {
      "scope": [
        "keyword.control.idyllium",
        "keyword.declaration.idyllium",
        "keyword.declaration.import.idyllium",
        "keyword.declaration.class.idyllium",
        "keyword.declaration.extends.idyllium",
        "keyword.operator.logical.idyllium",
        "constant.language.boolean.idyllium"
      ],
      "settings": { "foreground": "#8d3f75" }
    },
    {
      "scope": [
        "storage.type.primitive.idyllium",
        "storage.type.numeric.idyllium"
      ],
      "settings": { "foreground": "#1d659a" }
    },
    {
      "scope": [
        "entity.name.type.class.idyllium",
        "entity.other.inherited-class.idyllium"
      ],
      "settings": { "foreground": "#1b745c" }
    },
    {
      "scope": [
        "entity.name.function.idyllium",
        "entity.name.function.main.idyllium",
        "entity.name.function.member.idyllium",
        "support.function.builtin.idyllium"
      ],
      "settings": { "foreground": "#76620f" }
    },
    {
      "scope": [
        "entity.name.namespace.idyllium",
        "variable.language.this.idyllium",
        "variable.language.parent.idyllium",
        "variable.other.member.idyllium",
        "constant.other.color.idyllium"
      ],
      "settings": { "foreground": "#0d667f" }
    },
    {
      "scope": [
        "string.quoted.double.idyllium",
        "string.quoted.single.idyllium"
      ],
      "settings": { "foreground": "#87481f" }
    },
    {
      "scope": [
        "constant.numeric.float.idyllium",
        "constant.numeric.integer.idyllium"
      ],
      "settings": { "foreground": "#5b7027" }
    },
    {
      "scope": [
        "comment.block.idyllium",
        "comment.line.double-slash.idyllium"
      ],
      "settings": {
        "foreground": "#477237",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.operator.idyllium",
        "punctuation.idyllium"
      ],
      "settings": { "foreground": "#445253" }
    }
  ]
}
